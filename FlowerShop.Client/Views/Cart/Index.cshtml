@model FlowerShop.Application.CartDTO

@{
    ViewData["Title"] = "Giỏ hàng";
    var items = Model.CartItems?.ToList() ?? new List<FlowerShop.Application.CartItemDTO>();
    var totalAmount = items.Sum(x => x.TotalPrice);
}

@section Styles {
    <link rel="stylesheet" href="~/css/cart.css" asp-append-version="true" />
}

<div class="cart-page py-4 py-lg-5">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card cart-card border-0 shadow-sm">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="cart-title mb-0">Giỏ hàng của bạn</h3>
                        <span class="cart-badge">@items.Count sản phẩm</span>
                    </div>

                    @if (!items.Any())
                    {
                        <div class="cart-empty text-center py-5">
                            <div class="cart-empty-icon mb-3">🌸</div>
                            <h5 class="mb-2">Giỏ hàng trống</h5>
                            <p class="text-muted mb-4">Hãy chọn thêm những đóa hoa tươi đẹp nhé!</p>
                            <a asp-controller="Flower" asp-action="Index"
                                   class="btn btn-cart-primary rounded-pill px-4">
                                Xem sản phẩm ngay
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="cart-items">
                            @foreach (var item in items)
                            {
                                <div class="cart-item-row" id="item-@item.CartItemID"
                                     data-item-id="@item.CartItemID"
                                     data-unit-price="@item.UnitPrice">

                                    <div class="cart-item-image">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl" alt="@item.FlowerName" />
                                        }
                                        else
                                        {

                                            <div class="cart-item-placeholder">🌺</div>
                                        }
                                    </div>

                                    <div class="cart-item-info">
                                        <h5 class="cart-item-name">@item.FlowerName</h5>
                                        <p class="cart-item-price">@item.UnitPrice.ToString("N0") đ / sản phẩm</p>
                                    </div>

                                    <div class="cart-item-qty">
                                        <div class="qty-control">
                                            <button type="button" class="qty-btn qty-minus">−</button>
                                            <input type="number"
                                                   value="@item.Quantity"
                                                   min="1" max="99"
                                                   class="qty-input"
                                                   id="qty-@item.CartItemID" />
                                            <button type="button" class="qty-btn qty-plus">+</button>
                                        </div>
                                    </div>

                                    <div class="cart-item-total">
                                        <div class="item-total-wrap">
                                            <div class="item-total-price" id="total-@item.CartItemID">
                                                @item.TotalPrice.ToString("N0") đ
                                            </div>
                                            <button type="button" class="btn-remove"
                                                    data-item-id="@item.CartItemID"
                                                    onclick="removeItem(this)">
                                                ✕
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                      
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card cart-card border-0 shadow-sm sticky-lg-top">
                <div class="card-body p-4">
                    <h4 class="cart-title mb-4">Tổng đơn hàng</h4>

                    <div class="order-summary">
                        <div class="summary-row">
                            <span>Số lượng sản phẩm</span>
                            <span id="summaryItemCount">@items.Count</span>
                        </div>
                        <div class="summary-row">
                            <span>Tổng số hoa</span>
                            <span id="summaryTotalQty">@items.Sum(x => x.Quantity)</span>
                        </div>

                        <div class="summary-row summary-divider"></div>
                        <div class="summary-row summary-total">
                            <span>Tổng tiền</span>
                            <span class="total-amount" id="grandTotal">@totalAmount.ToString("N0") đ</span>
                        </div>

                    </div>

                    @if (items.Any())
                    {
                        <a asp-controller="Order" asp-action="Checkout"
                               class="btn btn-cart-primary w-100 rounded-pill py-2 mt-4">
                            Tiến hành thanh toán
                        </a>
                    }

                    <a asp-controller="Flower" asp-action="Index"
                           class="btn btn-cart-outline w-100 rounded-pill py-2 mt-2">
                        Tiếp tục mua hàng
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/cart.js" asp-append-version="true"></script>
}
