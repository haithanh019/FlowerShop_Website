@model FlowerShop.Application.UserRegisterDTO
@{
    ViewData["Title"] = "Đăng Ký";
}

@section Styles {
    <link rel="stylesheet" href="~/css/login.css" />
    <link rel="stylesheet" href="~/css/register.css" />
}

<div class="login-page">


    <svg class="deco-flower deco-flower--tl" width="280" height="280" viewBox="0 0 280 280"
         fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <ellipse cx="60" cy="200" rx="28" ry="10" fill="#8ecfbe" transform="rotate(-45 60 200)" opacity=".7"/>
        <ellipse cx="80" cy="220" rx="24" ry="9"  fill="#6bbfaa" transform="rotate(-60 80 220)" opacity=".6"/>
        <path d="M90 230 Q140 160 150 100" stroke="#b8d8c8" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        <g transform="translate(150,90)">
            <ellipse cx="0" cy="-22" rx="10" ry="18" fill="#f7b8c4" opacity=".9"/>
            <ellipse cx="0" cy="-22" rx="10" ry="18" fill="#f093a7" opacity=".4" transform="rotate(45)"/>
            <ellipse cx="0" cy="-22" rx="10" ry="18" fill="#f093a7" opacity=".4" transform="rotate(90)"/>
            <ellipse cx="0" cy="-22" rx="10" ry="18" fill="#f093a7" opacity=".4" transform="rotate(135)"/>
            <ellipse cx="0" cy="-22" rx="10" ry="18" fill="#f7b8c4" opacity=".9" transform="rotate(180)"/>
            <ellipse cx="0" cy="-22" rx="10" ry="18" fill="#f093a7" opacity=".4" transform="rotate(225)"/>
            <ellipse cx="0" cy="-22" rx="10" ry="18" fill="#f093a7" opacity=".4" transform="rotate(270)"/>
            <ellipse cx="0" cy="-22" rx="10" ry="18" fill="#f093a7" opacity=".4" transform="rotate(315)"/>
            <circle cx="0" cy="0" r="8" fill="#d4a96a" opacity=".9"/>
        </g>
        <g transform="translate(110,155)">
            <ellipse cx="0" cy="-14" rx="7" ry="12" fill="#f7c5d0" opacity=".85" transform="rotate(0)"/>
            <ellipse cx="0" cy="-14" rx="7" ry="12" fill="#f7c5d0" opacity=".85" transform="rotate(60)"/>
            <ellipse cx="0" cy="-14" rx="7" ry="12" fill="#f7c5d0" opacity=".85" transform="rotate(120)"/>
            <ellipse cx="0" cy="-14" rx="7" ry="12" fill="#f7c5d0" opacity=".85" transform="rotate(180)"/>
            <ellipse cx="0" cy="-14" rx="7" ry="12" fill="#f7c5d0" opacity=".85" transform="rotate(240)"/>
            <ellipse cx="0" cy="-14" rx="7" ry="12" fill="#f7c5d0" opacity=".85" transform="rotate(300)"/>
            <circle cx="0" cy="0" r="6" fill="#f9d58a"/>
        </g>
        <circle cx="165" cy="130" r="3" fill="#f7b8c4" opacity=".6"/>
        <circle cx="130" cy="170" r="2" fill="#b8e0d4" opacity=".7"/>
    </svg>

    <svg class="deco-flower deco-flower--tr" width="260" height="260" viewBox="0 0 260 260"
         fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <ellipse cx="200" cy="60"  rx="26" ry="9"  fill="#b8e0d4" transform="rotate(50 200 60)"  opacity=".7"/>
        <ellipse cx="185" cy="80"  rx="22" ry="8"  fill="#8ecfbe" transform="rotate(70 185 80)"  opacity=".6"/>
        <path d="M180 75 Q130 140 120 185" stroke="#b8d8c8" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        <g transform="translate(120,195)">
            <ellipse cx="0" cy="-20" rx="9" ry="16" fill="#f7b8c4" opacity=".9"/>
            <ellipse cx="0" cy="-20" rx="9" ry="16" fill="#f093a7" opacity=".5" transform="rotate(60)"/>
            <ellipse cx="0" cy="-20" rx="9" ry="16" fill="#f093a7" opacity=".5" transform="rotate(120)"/>
            <ellipse cx="0" cy="-20" rx="9" ry="16" fill="#f7b8c4" opacity=".9" transform="rotate(180)"/>
            <ellipse cx="0" cy="-20" rx="9" ry="16" fill="#f093a7" opacity=".5" transform="rotate(240)"/>
            <ellipse cx="0" cy="-20" rx="9" ry="16" fill="#f093a7" opacity=".5" transform="rotate(300)"/>
            <circle cx="0" cy="0" r="7" fill="#f9d58a" opacity=".9"/>
        </g>
        <circle cx="110" cy="165" r="2.5" fill="#f7b8c4" opacity=".6"/>
        <circle cx="140" cy="150" r="2"   fill="#b8e0d4" opacity=".7"/>
    </svg>

    <svg class="deco-flower deco-flower--bl" width="220" height="220" viewBox="0 0 220 220"
         fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <ellipse cx="40" cy="180" rx="24" ry="8" fill="#8ecfbe" transform="rotate(-30 40 180)" opacity=".6"/>
        <path d="M70 175 Q110 130 130 80" stroke="#b8d8c8" stroke-width="2" fill="none" stroke-linecap="round"/>
        <g transform="translate(135,70)">
            <ellipse cx="0" cy="-16" rx="8" ry="14" fill="#b8e0d4" opacity=".9"/>
            <ellipse cx="0" cy="-16" rx="8" ry="14" fill="#8ecfbe" opacity=".5" transform="rotate(60)"/>
            <ellipse cx="0" cy="-16" rx="8" ry="14" fill="#8ecfbe" opacity=".5" transform="rotate(120)"/>
            <ellipse cx="0" cy="-16" rx="8" ry="14" fill="#b8e0d4" opacity=".9" transform="rotate(180)"/>
            <ellipse cx="0" cy="-16" rx="8" ry="14" fill="#8ecfbe" opacity=".5" transform="rotate(240)"/>
            <ellipse cx="0" cy="-16" rx="8" ry="14" fill="#8ecfbe" opacity=".5" transform="rotate(300)"/>
            <circle cx="0" cy="0" r="6" fill="#f9d58a" opacity=".9"/>
        </g>
    </svg>

    <svg class="deco-flower deco-flower--br" width="240" height="240" viewBox="0 0 240 240"
         fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <ellipse cx="200" cy="200" rx="26" ry="9" fill="#8ecfbe" transform="rotate(30 200 200)" opacity=".65"/>
        <path d="M175 195 Q140 150 110 90" stroke="#b8d8c8" stroke-width="2" fill="none" stroke-linecap="round"/>
        <g transform="translate(105,80)">
            <ellipse cx="0" cy="-18" rx="9" ry="15" fill="#f7b8c4" opacity=".9"/>
            <ellipse cx="0" cy="-18" rx="9" ry="15" fill="#f093a7" opacity=".4" transform="rotate(60)"/>
            <ellipse cx="0" cy="-18" rx="9" ry="15" fill="#f093a7" opacity=".4" transform="rotate(120)"/>
            <ellipse cx="0" cy="-18" rx="9" ry="15" fill="#f7b8c4" opacity=".9" transform="rotate(180)"/>
            <ellipse cx="0" cy="-18" rx="9" ry="15" fill="#f093a7" opacity=".4" transform="rotate(240)"/>
            <ellipse cx="0" cy="-18" rx="9" ry="15" fill="#f093a7" opacity=".4" transform="rotate(300)"/>
            <circle cx="0" cy="0" r="7" fill="#d4a96a" opacity=".9"/>
        </g>
        <circle cx="130" cy="130" r="3" fill="#b8e0d4" opacity=".6"/>
    </svg>


    <div class="register-card-wrapper">
        <div class="login-card">

            <div class="brand-header">
                <div class="brand-logo">
                    <svg width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true">
                        <ellipse cx="18" cy="10" rx="5" ry="9"  fill="white" opacity=".95"/>
                        <ellipse cx="18" cy="10" rx="5" ry="9"  fill="white" opacity=".95" transform="rotate(60 18 18)"/>
                        <ellipse cx="18" cy="10" rx="5" ry="9"  fill="white" opacity=".85" transform="rotate(120 18 18)"/>
                        <ellipse cx="18" cy="10" rx="5" ry="9"  fill="white" opacity=".85" transform="rotate(180 18 18)"/>
                        <ellipse cx="18" cy="10" rx="5" ry="9"  fill="white" opacity=".85" transform="rotate(240 18 18)"/>
                        <ellipse cx="18" cy="10" rx="5" ry="9"  fill="white" opacity=".85" transform="rotate(300 18 18)"/>
                        <circle  cx="18" cy="18" r="5.5" fill="#f9d58a"/>
                    </svg>
                </div>
                <div class="brand-name">Shop Hoa Nguyên Hồng</div>
                <div class="brand-slogan">Tươi mát · Lãng mạn · Tinh tế</div>
                <div class="divider-floral">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                        <circle cx="7" cy="7" r="2.5" fill="#f7b8c4"/>
                        <ellipse cx="7" cy="3" rx="2" ry="3.5" fill="#f093a7" opacity=".7"/>
                        <ellipse cx="7" cy="3" rx="2" ry="3.5" fill="#f093a7" opacity=".7" transform="rotate(90 7 7)"/>
                        <ellipse cx="7" cy="3" rx="2" ry="3.5" fill="#f7b8c4" opacity=".6" transform="rotate(180 7 7)"/>
                        <ellipse cx="7" cy="3" rx="2" ry="3.5" fill="#f7b8c4" opacity=".6" transform="rotate(270 7 7)"/>
                    </svg>
                </div>
            </div>

            <p class="login-title">Tạo tài khoản mới</p>

            <div class="register-steps" aria-label="Tiến trình đăng ký">
                <div class="step-item done" aria-current="false">
                    <div class="step-circle">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                    </div>
                    <span class="step-label">Thông tin</span>
                </div>
                <div class="step-item active" aria-current="step">
                    <div class="step-circle">2</div>
                    <span class="step-label">Bảo mật</span>
                </div>
                <div class="step-item" aria-current="false">
                    <div class="step-circle">3</div>
                    <span class="step-label">Xác nhận</span>
                </div>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-floral">
                    @Html.ValidationSummary(false, "", new { @class = "" })
                </div>
            }

            <form asp-action="Register" method="post" novalidate id="registerForm">
                @Html.AntiForgeryToken()

                <div class="form-grid-2">

                    <div class="form-group form-group--full" style="animation-delay:0.22s">
                        <label asp-for="FullName" class="form-label-custom">Họ &amp; Tên</label>
                        <div class="input-wrapper">
                            <span class="input-icon">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                    <circle cx="12" cy="7" r="4"/>
                                </svg>
                            </span>
                            <input asp-for="FullName"
                                   class="form-control-custom"
                                   placeholder="Nguyễn Văn A"
                                   autocomplete="name" />
                        </div>
                        <span asp-validation-for="FullName" class="validation-msg"></span>
                    </div>

                    <div class="form-group form-group--full" style="animation-delay:0.28s">
                        <label asp-for="Email" class="form-label-custom">Email</label>
                        <div class="input-wrapper">
                            <span class="input-icon">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <rect x="2" y="4" width="20" height="16" rx="3"/>
                                    <path d="M2 7l10 7 10-7"/>
                                </svg>
                            </span>
                            <input asp-for="Email"
                                   class="form-control-custom"
                                   placeholder="email@example.com"
                                   autocomplete="email" />
                        </div>
                        <span asp-validation-for="Email" class="validation-msg"></span>
                    </div>

                    <div class="form-group" style="animation-delay:0.34s">
                        <label asp-for="Password" class="form-label-custom">Mật Khẩu</label>
                        <div class="input-wrapper">
                            <span class="input-icon">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <rect x="3" y="11" width="18" height="11" rx="2"/>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                                </svg>
                            </span>
                            <input asp-for="Password"
                                   id="passwordInput"
                                   type="password"
                                   class="form-control-custom"
                                   placeholder="••••••••"
                                   autocomplete="new-password" />
                            <button type="button" class="toggle-password" id="togglePassword"
                                    aria-label="Hiện/ẩn mật khẩu">
                                <svg id="eyeIcon1" width="16" height="16" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                     stroke-linejoin="round" aria-hidden="true">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                </svg>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="validation-msg"></span>

                        <div class="strength-wrap" id="strengthWrap" style="display:none">
                            <div class="strength-bars">
                                <div class="strength-bar" id="sb1"></div>
                                <div class="strength-bar" id="sb2"></div>
                                <div class="strength-bar" id="sb3"></div>
                                <div class="strength-bar" id="sb4"></div>
                            </div>
                            <span class="strength-label" id="strengthLabel"></span>
                        </div>
                    </div>

                    <div class="form-group" style="animation-delay:0.38s">
                        <label asp-for="ConfirmPassword" class="form-label-custom">Xác Nhận</label>
                        <div class="input-wrapper">
                            <span class="input-icon">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                                </svg>
                            </span>
                            <input asp-for="ConfirmPassword"
                                   id="confirmInput"
                                   type="password"
                                   class="form-control-custom"
                                   placeholder="••••••••"
                                   autocomplete="new-password" />
                            <button type="button" class="toggle-password" id="toggleConfirm"
                                    aria-label="Hiện/ẩn xác nhận mật khẩu">
                                <svg id="eyeIcon2" width="16" height="16" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                     stroke-linejoin="round" aria-hidden="true">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                </svg>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="validation-msg"></span>
                        <div class="match-indicator" id="matchIndicator">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
                                 id="matchIcon">
                            </svg>
                            <span id="matchText"></span>
                        </div>
                    </div>

                    <div class="form-group form-group--full" style="animation-delay:0.42s">
                        <label asp-for="PhoneNumber" class="form-label-custom">
                            Số Điện Thoại
                            <span style="font-weight:300;letter-spacing:0;text-transform:none;font-size:0.7rem;color:var(--text-light);margin-left:0.3rem">(không bắt buộc)</span>
                        </label>
                        <div class="input-wrapper">
                            <span class="input-icon">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.79 19.79 0 0 1 11.61 19a19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.34 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                                </svg>
                            </span>
                            <input asp-for="PhoneNumber"
                                   class="form-control-custom"
                                   placeholder="090 xxx xxxx"
                                   autocomplete="tel" />
                        </div>
                        <span asp-validation-for="PhoneNumber" class="validation-msg"></span>
                    </div>

                </div>

                <div class="terms-row">
                    <label class="checkbox-custom">
                        <input type="checkbox" id="termsCheck" required />
                        <span class="checkmark"></span>
                    </label>
                    <p class="terms-text">
                        Tôi đồng ý với
                        <a asp-area="" asp-controller="Home" asp-action="Terms">Điều khoản sử dụng</a>
                        và
                        <a asp-area="" asp-controller="Home" asp-action="Privacy">Chính sách bảo mật</a>
                        của Bloom &amp; Petal
                    </p>
                </div>

                <button type="submit" class="btn-login" id="submitBtn" disabled>
                    Tạo Tài Khoản
                </button>

            </form>

            <div class="card-footer-links">
                Đã có tài khoản?
                <a asp-action="Login">Đăng nhập ngay</a>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
        <script src="~/js/register.js" asp-append-version="true"></script>

}
