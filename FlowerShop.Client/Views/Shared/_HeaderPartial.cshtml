@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
<div class="header-top-bar" role="marquee" aria-label="Thông báo khuyến mãi">
    <div class="top-bar-track" aria-hidden="true">
        @for (int i = 0; i < 2; i++)
        {
            <span class="top-bar-item">
                <span class="dot"></span>
                Miễn phí giao hàng cho đơn từ <span class="highlight">399.000đ</span>
            </span>
            <span class="top-bar-item">
                <span class="dot"></span>
                Hoa tươi nhập khẩu mỗi ngày &nbsp;🌸
            </span>
            <span class="top-bar-item">
                <span class="dot"></span>
                Đặt trước 12:00 — giao trong ngày <span class="highlight">nội thành Quảng Trị (Quảng Bình cũ)</span>
            </span>
            <span class="top-bar-item">
                <span class="dot"></span>
                Ưu đãi thành viên mới: <span class="highlight">giảm 15%</span> đơn đầu tiên
            </span>
            <span class="top-bar-item">
                <span class="dot"></span>
                Hotline: <span class="highlight">0522551166</span> — mở cửa 7:00 – 20:00
            </span>
        }
    </div>
</div>

@* ── Main Navbar ── *@
<header>
    <nav class="navbar-floral" role="navigation" aria-label="Điều hướng chính">
        <div class="container-fluid">

            @* ── Brand Logo ── *@
            <a asp-area="" asp-controller="Home" asp-action="Index"
               class="navbar-brand-floral" aria-label="Bloom & Petal - Trang chủ">
                <div class="brand-icon-wrap" aria-hidden="true">
                    <svg width="22" height="22" viewBox="0 0 36 36" fill="none">
                        <ellipse cx="18" cy="9" rx="5" ry="9" fill="white" opacity=".95" />
                        <ellipse cx="18" cy="9" rx="5" ry="9" fill="white" opacity=".9" transform="rotate(60 18 18)" />
                        <ellipse cx="18" cy="9" rx="5" ry="9" fill="white" opacity=".9" transform="rotate(120 18 18)" />
                        <ellipse cx="18" cy="9" rx="5" ry="9" fill="white" opacity=".85" transform="rotate(180 18 18)" />
                        <ellipse cx="18" cy="9" rx="5" ry="9" fill="white" opacity=".85" transform="rotate(240 18 18)" />
                        <ellipse cx="18" cy="9" rx="5" ry="9" fill="white" opacity=".85" transform="rotate(300 18 18)" />
                        <circle cx="18" cy="18" r="5.5" fill="#f9d58a" />
                    </svg>
                </div>
                <div class="brand-text-wrap">
                    <span class="brand-text-name">Shop Hoa Nguyên Hồng</span>
                </div>
                <div class="brand-text-wrap">
                    <span class="brand-text-sub">Flower Shop</span>
                </div>
            </a>

            @* ── Center Navigation ── *@
            <ul class="navbar-nav-floral" role="menubar">

                <li class="nav-item-floral" role="none">
                    <a asp-area="" asp-controller="Home" asp-action="Index"
                       class="nav-link-floral" role="menuitem">Trang Chủ</a>
                </li>

                @* Dropdown: Sản Phẩm *@
                <li class="nav-item-floral" role="none">
                    <a asp-area="" asp-controller="Product" asp-action="Index"
                       class="nav-link-floral" role="menuitem" aria-haspopup="true" aria-expanded="false">
                        Sản Phẩm
                        <svg class="chevron" width="13" height="13" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.5" stroke-linecap="round"
                             stroke-linejoin="round" aria-hidden="true">
                            <polyline points="6 9 12 15 18 9" />
                        </svg>
                    </a>
                    <ul class="nav-dropdown" role="menu">
                        <li role="none">
                            <a asp-area="" asp-controller="Product" asp-action="Bouquet" role="menuitem">
                                <span class="dd-icon">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22V12M12 12C12 12 7 9 7 5a5 5 0 0 1 10 0c0 4-5 7-5 7z" /></svg>
                                </span>
                                Bó Hoa
                            </a>
                        </li>
                        <li role="none">
                            <a asp-area="" asp-controller="Product" asp-action="Vase" role="menuitem">
                                <span class="dd-icon">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 2h8l1 7H7L8 2z" /><path d="M7 9c0 5 2 9 5 9s5-4 5-9" /></svg>
                                </span>
                                Hoa Cắm Bình
                            </a>
                        </li>
                        <li role="none">
                            <a asp-area="" asp-controller="Product" asp-action="Basket" role="menuitem">
                                <span class="dd-icon">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" /><line x1="3" y1="6" x2="21" y2="6" /></svg>
                                </span>
                                Giỏ Hoa Quà Tặng
                            </a>
                        </li>
                        <li role="none">
                            <a asp-area="" asp-controller="Product" asp-action="Seasonal" role="menuitem">
                                <span class="dd-icon">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z" /><path d="M12 6v6l4 2" /></svg>
                                </span>
                                Hoa Theo Mùa
