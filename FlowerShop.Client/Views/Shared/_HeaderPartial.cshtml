                         stroke="currentColor" stroke-width="2" stroke-linecap="round"
                         stroke-linejoin="round" aria-hidden="true">
                        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                        <line x1="3" y1="6" x2="21" y2="6" />
                        <path d="M16 10a4 4 0 0 1-8 0" />
                    </svg>
                    @* Badge: thay ViewBag.CartCount bằng số thực từ controller *@
                    @if (ViewBag.CartCount != null && ViewBag.CartCount > 0)
                    {
                        <span class="action-badge" aria-label="@ViewBag.CartCount sản phẩm">
                            @ViewBag.CartCount
                        </span>
                    }
                </a>

                <div class="action-divider" aria-hidden="true"></div>

                @* Auth buttons *@
                @if (!string.IsNullOrEmpty(HttpContextAccessor.HttpContext?.Session.GetString("JWToken")))
                {
                    @* Account dropdown *@
                    <a asp-area="" asp-controller="Auth" asp-action="Profile"
                       class="action-btn" aria-label="Tài khoản của tôi">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round"
                             stroke-linejoin="round" aria-hidden="true">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                            <circle cx="12" cy="7" r="4" />
                        </svg>
                    </a>
                    <a asp-area="" asp-controller="Auth" asp-action="Logout"
                       class="btn-drawer-outline">Đăng Xuất</a>
                }
                else
                {
                    <a asp-area="" asp-controller="Auth" asp-action="Login"
                       class="btn-nav-cta">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.2" stroke-linecap="round"
                             stroke-linejoin="round" aria-hidden="true">
                            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                            <polyline points="10 17 15 12 10 7" />
                            <line x1="15" y1="12" x2="3" y2="12" />
                        </svg>
                        Đăng Nhập
                    </a>
                }

                @* Mobile toggle *@
                <button class="navbar-toggler-floral" id="drawerToggle"
                        type="button" aria-label="Mở menu" aria-expanded="false"
                        aria-controls="mobileDrawer">
                    <span class="toggler-bar"></span>
                    <span class="toggler-bar"></span>
                    <span class="toggler-bar"></span>
                </button>

            </div>
        </div>
    </nav>
</header>

@* ── Search Overlay ── *@
<div class="search-overlay" id="searchOverlay" role="dialog"
     aria-modal="true" aria-label="Tìm kiếm sản phẩm">
    <div class="search-box">
        <div class="search-input-wrap">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round"
                 stroke-linejoin="round" aria-hidden="true">
                <circle cx="11" cy="11" r="8" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
            <input type="search" class="search-input" id="searchInput"
                   placeholder="Tìm kiếm hoa, bó hoa, quà tặng..."
                   autocomplete="off" />
            <button type="button" class="search-close" id="searchClose" aria-label="Đóng tìm kiếm">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.2" stroke-linecap="round"
                     stroke-linejoin="round" aria-hidden="true">
                    <line x1="18" y1="6" x2="6" y2="18" />
                    <line x1="6" y1="6" x2="18" y2="18" />
                </svg>
            </button>
        </div>
        <div class="search-hints">
            <a asp-area="" asp-controller="Product" asp-action="Index"
               asp-route-q="hồng" class="search-hint-tag">🌹 Hoa hồng</a>
            <a asp-area="" asp-controller="Product" asp-action="Index"
               asp-route-q="hướng dương" class="search-hint-tag">🌻 Hướng dương</a>
            <a asp-area="" asp-controller="Product" asp-action="Index"
               asp-route-q="sinh nhật" class="search-hint-tag">🎂 Sinh nhật</a>
            <a asp-area="" asp-controller="Product" asp-action="Index"
               asp-route-q="cưới" class="search-hint-tag">💒 Đám cưới</a>
            <a asp-area="" asp-controller="Product" asp-action="Index"
               asp-route-q="8/3" class="search-hint-tag">🎀 Quà 8/3</a>
        </div>
    </div>
</div>

@* ── Mobile Drawer Backdrop ── *@
