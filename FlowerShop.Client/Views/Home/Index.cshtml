@using FlowerShop.Client.Models.Home
@model HomeViewModel

@{
    ViewData["Title"] = "Trang chủ - Flower Shop";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

<div class="home-wrapper pt-4">
    <div class="container">

        <div id="homeBanner" class="carousel slide mb-4 shadow-sm rounded" data-bs-ride="carousel">
            <div class="carousel-inner rounded">
                <div class="carousel-item active">
                    <img src="https://via.placeholder.com/1200x350/ffdde1/ee4d2d?text=Chao+Mung+Den+Voi+Flower+Shop" class="d-block w-100" style="object-fit: cover; height: 350px;" alt="Banner 1">
                </div>
            </div>
        </div>

        <div class="bg-white p-3 mb-4 shadow-sm rounded">
            <h5 class="text-uppercase text-secondary mb-3" style="font-size: 16px; font-weight: 500;">Danh Mục</h5>
            <div class="d-flex flex-wrap text-center category-list">
                @if (Model.Categories != null && Model.Categories.Any())
                {
                    foreach (var cat in Model.Categories)
                    {
                        <a href="/Category/Details/@cat.CategoryID" class="text-decoration-none text-dark category-item">
                            <div class="category-img-box mx-auto mb-2 rounded-circle">
                                <img src="https://via.placeholder.com/40x40/f0f0f0/999?text=@cat.Name.Substring(0, 1)" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover;" alt="@cat.Name">
                            </div>
                            <span style="font-size: 14px; display: block;">@cat.Name</span>
                        </a>
                    }
                }
                else
                {
                    <p class="text-muted w-100 text-start ms-2">Đang cập nhật danh mục...</p>
                }
            </div>
        </div>

        <div class="shopee-recommendation">
            <div class="bg-white p-3 mb-2 shadow-sm sticky-top" style="top: 0; z-index: 10; border-bottom: 2px solid #ee4d2d;">
                <h4 class="text-uppercase m-0" style="font-weight: 500; color: #ee4d2d;">Gợi ý hôm nay</h4>
            </div>

            <div class="row row-cols-2 row-cols-md-4 row-cols-lg-5 g-2 mt-2">
                @if (Model.Flowers != null && Model.Flowers.Any())
                {
                    foreach (var flower in Model.Flowers)
                    {
                        var mainImageUrl = flower.FlowerImages != null && flower.FlowerImages.Any()
                        ? flower.FlowerImages.First().Url
                        : "https://via.placeholder.com/200x200?text=No+Image";

                        <div class="col">
                            <a href="/Flower/Details/@flower.FlowerID" class="text-decoration-none">
                                <div class="card h-100 border-0 shadow-sm product-card">
                                    <img src="@mainImageUrl" class="card-img-top rounded-top" style="height: 190px; object-fit: cover;" alt="@flower.FlowerName">
                                    <div class="card-body p-2 d-flex flex-column bg-white">
                                        <p class="card-text product-title mb-2">@flower.FlowerName</p>

                                        <div class="mt-auto d-flex justify-content-between align-items-center">
                                            <span style="color: #ee4d2d; font-size: 16px;" class="fw-bold">₫@flower.Price.ToString("N0")</span>
                                            <span class="text-muted" style="font-size: 12px;">Kho: @flower.StockQuantity</span>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5">
                        <p class="text-muted">Chưa có sản phẩm nào được hiển thị.</p>
                    </div>
                }
            </div>

            @if (Model.Flowers != null && Model.Flowers.Count() >= 10)
            {
                <div class="text-center mt-4">
                    <button id="btnLoadMore" class="btn btn-outline-secondary px-5 py-2 bg-white text-dark" style="width: 350px; font-weight: 500;">Xem Thêm</button>
                </div>
            }
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/js/home.js" asp-append-version="true"></script>
}