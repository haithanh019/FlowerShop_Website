<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin FlowerShop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/admin/admin.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body class="admin-body">

    @* ── Toast Data (an toàn với ký tự đặc biệt) ── *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div id="toastData"
             data-msg="@TempData["SuccessMessage"]"
             data-type="success"
             style="display:none"></div>
    }
    else if (TempData["ErrorMessage"] != null)
    {
        <div id="toastData"
             data-msg="@TempData["ErrorMessage"]"
             data-type="error"
             style="display:none"></div>
    }

    <aside class="admin-sidebar">
        <div class="admin-sidebar-logo">
            <span class="logo-icon">🌸</span>
            <div>
                <div class="logo-text">FlowerShop</div>
                <div class="logo-sub">Admin Panel</div>
            </div>
        </div>

        <nav class="admin-nav">
            <div class="admin-nav-label">Quản lý</div>

            <a asp-area="Admin" asp-controller="Home" asp-action="Index"
                   class="admin-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                <span class="nav-icon">📊</span>
                <span>Tổng quan</span>
            </a>

            <a asp-area="Admin" asp-controller="Flower" asp-action="Index"
                   class="admin-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Flower" ? "active" : "")">
                <span class="nav-icon">🌺</span>
                <span>Hoa</span>
            </a>

            <a asp-area="Admin" asp-controller="Category" asp-action="Index"
                   class="admin-nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")">
                <span class="nav-icon">🏷️</span>
                <span>Danh mục</span>
            </a>

            <div class="admin-nav-label" style="margin-top:12px">Hệ thống</div>

            <a asp-area="" asp-controller="Home" asp-action="Index"
                   class="admin-nav-item" target="_blank">
                <span class="nav-icon">🌐</span>
                <span>Xem trang web</span>
            </a>
        </nav>

        <div class="admin-sidebar-footer">
            <a asp-area="" asp-controller="Auth" asp-action="Logout">
                <span>🚪</span>
                <span>Đăng xuất</span>
            </a>
        </div>
    </aside>

    <div class="admin-main">
        <header class="admin-topbar">
            <div class="admin-topbar-title">@(ViewData["Title"] ?? "Admin")</div>
            <div class="admin-topbar-user">
                <div class="admin-avatar">A</div>
                <span>Admin</span>
            </div>
        </header>

        <div class="admin-content">
            @RenderBody()
        </div>
    </div>

    @* ── Toast UI ── *@
    <div id="adminToast" class="admin-toast" role="alert">
        <span id="adminToastIcon"></span>
        <span id="adminToastMsg"></span>
        <button onclick="document.getElementById('adminToast').classList.remove('show')"
                style="background:none;border:none;color:inherit;
            font-size:1rem;cursor:pointer;margin-left:auto">
            ✕
        </button>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/admin/site-admin.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
